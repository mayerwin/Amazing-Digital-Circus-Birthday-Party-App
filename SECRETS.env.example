# ─────────────────────────────────────────────────────────────────────────
#  Copy this file to  SECRETS.env  (which is gitignored) and fill in values.
#  It is loaded into the environment at startup and never committed.
#
#  You ONLY need this for *gated* Hugging Face models (some of the optional
#  premium voices). The default voice (Chatterbox) and the recommended
#  OmniVoice voice do NOT require any token — you can ignore this file.
# ─────────────────────────────────────────────────────────────────────────

# Hugging Face access token — create one at https://huggingface.co/settings/tokens
# (needed to download gated weights for a few optional models).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: only set these if you deliberately want "Talk to Caine" to bill a
# pay-as-you-go Anthropic API key instead of using a local Claude CLI session.
# Leave them unset to use your logged-in Claude CLI.
# ANTHROPIC_API_KEY=
